{
  "name": "sermonsync",
  "version": "0.1.1",
  "description": "SermonSync: AI-powered Sermon Transcription and Bible Tagging.",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "author": "SermonSync Team",
  "license": "MIT",
  "sermonSync": {
    "nAtlasDownloadUrl": "https://github.com/Darkwaczy/Live/releases/latest/download/n-atlas-service.exe"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:electron\" \"npm:dev:react\"",
    "dev:react": "vite",
    "dev:electron": "npm run build:electron:main && wait-on http://localhost:5173 && electron .",
    "build": "npm run build:react && npm run build:electron:main && npm run build:electron",
    "build:react": "vite build",
    "build:electron:main": "tsc -p tsconfig.node.json --outDir dist-electron",
    "build:electron": "electron-builder",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:sync-server": "ts-node --transpile-only socket-server.ts",
    "download:model": ".venv\\Scripts\\python services/download_model.py",
    "build:sidecar": ".venv\\Scripts\\pyinstaller --onefile --name n-atlas-service --distpath sidecar-dist --workpath .pyinstaller-build --specpath . services/n_atlas_service.py && .venv\\Scripts\\pyinstaller --onefile --name ndi-broadcast-service --distpath sidecar-dist --workpath .pyinstaller-build --specpath . services/ndi_broadcast_service.py"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.0.0",
    "lucide-react": "^1.7.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "socket.io-client": "^4.0.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.4.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/socket.io-client": "^3.0.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "electron": "26.6.10",
    "electron-builder": "^24.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.0.0",
    "express": "^4.18.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "socket.io": "^4.8.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.1",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.sermonsync.app",
    "productName": "SermonSync",
    "copyright": "Copyright © 2026 SermonSync Team",
    "compression": "maximum",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/index.html",
      "dist/assets/**",
      "dist/bibles/**",
      "dist/lyrics/**",
      "dist/models/vosk-model.tar.gz",
      "dist/*.json",
      "dist/*.png",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "sidecar-dist/ndi-broadcast-service.exe",
        "to": "bin/ndi-broadcast-service.exe"
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "bible-temp.db",
        "to": "bible-temp.db"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png",
      "publisherName": "SermonSync Team",
      "cscLink": null,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png",
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
